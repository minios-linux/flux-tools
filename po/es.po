#: bin/fbliveapp:17
msgid "VLC Video Player"
msgstr "Reproductor de vídeo"

#: bin/fbliveapp:18
msgid ""
"VLC is a free and open source multimedia player that plays most media files "
"and streaming protocols."
msgstr ""
"VLC es un reproductor multimedia libre y de código abierto que reproduce la "
"mayoría de los archivos multimedia y protocolos de transmisión."

#: bin/fbliveapp:28
msgid "Chromium Web Browser"
msgstr "Navegador Chromium"

#: bin/fbliveapp:29
msgid ""
"Chromium is a free and open source version of the famous Chrome browser, "
"developed by Google."
msgstr ""
"Chromium es una versión libre y de código abierto del conocido navegador "
"Chrome, desarrollado por Google."

#: bin/fbliveapp:38
msgid "Firefox Web Browser"
msgstr "Navegador Firefox"

#: bin/fbliveapp:39
msgid "Firefox is a free and open source browser."
msgstr "Firefox es un navegador libre y de código abierto."

#: bin/fbliveapp:52
msgid "MiniOS Installer"
msgstr "Instalador de MiniOS"

#: bin/fbliveapp:53
msgid "MiniOS Installer allows you to install MiniOS on the media."
msgstr "El instalador de MiniOS permite instalar MiniOS en el medio."

#: bin/fbliveapp:62
msgid "MiniOS Configurator"
msgstr "Configurador de MiniOS"

#: bin/fbliveapp:63
msgid "MiniOS Configurator allows you to configure MiniOS."
msgstr "El configurador de MiniOS permite configurar MiniOS."

#: bin/fbliveapp:72
msgid "MiniOS Session Manager"
msgstr "Gestor de sesiones de MiniOS"

#: bin/fbliveapp:73
msgid "MiniOS Session Manager allows you to manage persistent sessions."
msgstr ""
"El gestor de sesiones de MiniOS permite gestionar sesiones persistentes."

#: bin/fbliveapp:82
msgid "MiniOS Kernel Manager"
msgstr "Gestor de kernels de MiniOS"

#: bin/fbliveapp:83
msgid "MiniOS Kernel Manager allows you to manage Linux kernels."
msgstr "El gestor de kernels de MiniOS permite gestionar Linux-Kernels."

#: bin/fbliveapp:110
msgid "Error"
msgstr "Error"

#: bin/fbliveapp:110
msgid "only works in 64bit version of MiniOS"
msgstr "solo funciona en la versión de 64 bits de MiniOS"

#: bin/fbliveapp:110
msgid "OK"
msgstr "Aceptar"

#: bin/fbliveapp:114
msgid "Question"
msgstr "Pregunta"

#: bin/fbliveapp:114
msgid " is not yet installed. Do you like to download and install it now?"
msgstr " no está instalado todavía. ¿Desea descargarlo e instalarlo ahora?"

#: bin/fbliveapp:114
msgid "Yes"
msgstr "Sí"

#: bin/fbliveapp:114
msgid "No"
msgstr "No"

